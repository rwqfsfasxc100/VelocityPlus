			"version_hash": 0
		},
		"DIALOG_SALVAGE_BYE_BEGINNER_2": {
			"string": "Це все від SRO на цей час! Ці звіти призначені виключно для членів організації з оплаченою підпискою — і ми відстежуємо витоки. Знаю, що багато хто з вас тут часті гості, тож якщо хочете зберегти підписку — тримайте координати в таємниці. Літайте безпечно!",
			"version_hash": 0
		},
		"DIALOG_SALVAGE_BYE_BEGINNER_3": {
